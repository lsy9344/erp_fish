// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

enum UserRole {
  HEADQUARTERS
  STORE_MANAGER
}

enum StoreAccessMode {
  ALL_STORES
  ASSIGNED_STORES
}

enum PermissionAction {
  LEDGER_CREATE
  LEDGER_EDIT
  LEDGER_HQ_CLOSE
  CORRECTION_CREATE
  UPLOAD_PREVIEW
  UPLOAD_COMMIT
  SETTINGS_MANAGE
  REPORT_VIEW
  EXPORT_CREATE
  USER_PERMISSION_MANAGE
}

enum DailyLedgerStatus {
  IN_PROGRESS
  IN_REVIEW
  HEADQUARTERS_CLOSED
  HOLIDAY
}

enum LedgerInputCodeGroup {
  PAYMENT_METHOD
  EXPENSE_ITEM
  LOSS_TYPE
}

enum InventoryCarryoverSource {
  OPENING_SNAPSHOT
  PREVIOUS_CLOSED_LEDGER
  PREVIOUS_SAVED_LEDGER
  MANUAL
}

enum InventoryCarryoverStatus {
  PREVIOUS_CARRYOVER
  REVIEW_REQUIRED
  CARRYOVER_EMPTY
  CARRYOVER_RECHECK_REQUIRED
  OPENING_CARRYOVER
  DATA_INSUFFICIENT
  POLICY_UNCONFIRMED
}

enum InventoryAdjustmentAmountStatus {
  POLICY_UNCONFIRMED
  CONFIRMED
}

enum LedgerPurchaseSource {
  MANUAL
  ECOUNT_UPLOAD
}

enum InventoryLotSource {
  OPENING
  PREVIOUS_CARRYOVER
  PURCHASE
  LEGACY_OPENING
}

enum CorrectionTargetType {
  LEDGER_FIELD
  PAYMENT_FIELD
  EXPENSE_ROW
  PURCHASE_ROW
  INVENTORY_ROW
  LOSS_ROW
  CALCULATED_METRIC
}

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

model Store {
  id          String   @id @default(cuid())
  name        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  assignments               UserStoreAssignment[]
  updatedBy                 User?                      @relation("StoreUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  dailyLedgers              DailyLedger[]
  inventoryOpeningSnapshots InventoryOpeningSnapshot[]
  ledgerInputCodeAliases    LedgerInputCodeStoreAlias[]
  salesPricePlans           StoreSalesPricePlan[]
  headquartersExpenses      HeadquartersExpense[]

  @@index([isActive])
  @@index([updatedById])
}

model Product {
  id               String   @id @default(cuid())
  name             String
  category         String
  spec             String
  defaultUnitPrice Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  updatedById      String?

  updatedBy                  User?                       @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  purchaseStandards          PurchaseStandard[]
  ledgerPurchaseItems        LedgerPurchaseItem[]
  ledgerInventoryItems       LedgerInventoryItem[]
  ledgerInventoryFifoLots    LedgerInventoryFifoLot[]
  ledgerInventoryAdjustments LedgerInventoryAdjustment[]
  ledgerLossItems            LedgerLossItem[]
  inventoryOpeningSnapshots  InventoryOpeningSnapshot[]
  salesPricePlans            StoreSalesPricePlan[]

  @@unique([name, category, spec])
  @@index([category])
  @@index([isActive])
  @@index([updatedById])
}

model PurchaseStandard {
  id                String   @id @default(cuid())
  productId         String   @unique
  standardUnitPrice Int?
  referenceInfo     String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedById       String?

  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  updatedBy           User?                @relation("PurchaseStandardUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  ledgerPurchaseItems LedgerPurchaseItem[]

  @@index([isActive])
  @@index([updatedById])
}

model LedgerInputCode {
  id           String               @id @default(cuid())
  group        LedgerInputCodeGroup
  name         String
  displayOrder Int
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  updatedById  String?

  updatedBy       User?            @relation("LedgerInputCodeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  ledgerExpenses  LedgerExpense[]
  ledgerLossItems LedgerLossItem[]
  storeAliases    LedgerInputCodeStoreAlias[]

  @@unique([group, name])
  @@index([group, displayOrder])
  @@index([isActive])
  @@index([updatedById])
}

// 미팅 결정(2026-06-21): 코드 등록은 본사가 하되, 각 지점은 화면 표시명만
// 자기 지점용으로 덮어쓸 수 있다. 코드 자체(키/값/활성)는 본사 전용으로 유지.
model LedgerInputCodeStoreAlias {
  id                String   @id @default(cuid())
  ledgerInputCodeId String
  storeId           String
  displayName       String
  createdById       String
  updatedById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ledgerInputCode LedgerInputCode @relation(fields: [ledgerInputCodeId], references: [id], onDelete: Cascade)
  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("LedgerInputCodeStoreAliasCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User            @relation("LedgerInputCodeStoreAliasUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@unique([ledgerInputCodeId, storeId])
  @@index([storeId])
  @@index([createdById])
  @@index([updatedById])
}

model UserStoreAssignment {
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@index([storeId])
}

model PermissionProfile {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  description     String?
  isSystem        Boolean         @default(false)
  isActive        Boolean         @default(true)
  storeAccessMode StoreAccessMode
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  actions PermissionProfileAction[]
  users   UserPermissionProfile[]

  @@index([isActive])
  @@index([storeAccessMode])
}

model PermissionProfileAction {
  profileId String
  action    PermissionAction
  createdAt DateTime         @default(now())

  profile PermissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([profileId, action])
  @@index([action])
}

model UserPermissionProfile {
  userId    String
  profileId String
  createdAt DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile PermissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([userId, profileId])
  @@index([profileId])
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                String                      @id @default(cuid())
  name                              String?
  email                             String?                     @unique
  emailVerified                     DateTime?
  image                             String?
  role                              UserRole                    @default(STORE_MANAGER)
  passwordHash                      String?
  isActive                          Boolean                     @default(true)
  createdAt                         DateTime                    @default(now())
  updatedAt                         DateTime                    @default(now()) @updatedAt
  accounts                          Account[]
  sessions                          Session[]
  posts                             Post[]
  storeAssignments                  UserStoreAssignment[]
  permissionProfiles                UserPermissionProfile[]
  updatedStores                     Store[]                     @relation("StoreUpdatedBy")
  updatedProducts                   Product[]                   @relation("ProductUpdatedBy")
  updatedPurchaseStandards          PurchaseStandard[]          @relation("PurchaseStandardUpdatedBy")
  updatedLedgerInputCodes           LedgerInputCode[]           @relation("LedgerInputCodeUpdatedBy")
  updatedAnomalyThresholdSettings   AnomalyThresholdSetting[]   @relation("AnomalyThresholdSettingUpdatedBy")
  createdDailyLedgers               DailyLedger[]               @relation("LedgerCreatedBy")
  updatedDailyLedgers               DailyLedger[]               @relation("LedgerUpdatedBy")
  submittedDailyLedgers             DailyLedger[]               @relation("LedgerSubmittedBy")
  closedDailyLedgers                DailyLedger[]               @relation("LedgerClosedBy")
  createdLedgerExpenses             LedgerExpense[]             @relation("LedgerExpenseCreatedBy")
  updatedLedgerExpenses             LedgerExpense[]             @relation("LedgerExpenseUpdatedBy")
  createdLedgerPurchaseItems        LedgerPurchaseItem[]        @relation("LedgerPurchaseItemCreatedBy")
  updatedLedgerPurchaseItems        LedgerPurchaseItem[]        @relation("LedgerPurchaseItemUpdatedBy")
  createdLedgerInventoryItems       LedgerInventoryItem[]       @relation("LedgerInventoryItemCreatedBy")
  updatedLedgerInventoryItems       LedgerInventoryItem[]       @relation("LedgerInventoryItemUpdatedBy")
  createdLedgerInventoryAdjustments LedgerInventoryAdjustment[] @relation("LedgerInventoryAdjustmentCreatedBy")
  updatedLedgerInventoryAdjustments LedgerInventoryAdjustment[] @relation("LedgerInventoryAdjustmentUpdatedBy")
  createdLedgerLossItems            LedgerLossItem[]            @relation("LedgerLossItemCreatedBy")
  updatedLedgerLossItems            LedgerLossItem[]            @relation("LedgerLossItemUpdatedBy")
  createdLedgerLaborItems           LedgerLaborItem[]           @relation("LedgerLaborItemCreatedBy")
  updatedLedgerLaborItems           LedgerLaborItem[]           @relation("LedgerLaborItemUpdatedBy")
  createdCorrectionRecords          CorrectionRecord[]          @relation("CorrectionRecordCreatedBy")
  createdLedgerInputCodeAliases     LedgerInputCodeStoreAlias[] @relation("LedgerInputCodeStoreAliasCreatedBy")
  updatedLedgerInputCodeAliases     LedgerInputCodeStoreAlias[] @relation("LedgerInputCodeStoreAliasUpdatedBy")
  createdStoreSalesPricePlans       StoreSalesPricePlan[]       @relation("StoreSalesPricePlanCreatedBy")
  updatedStoreSalesPricePlans       StoreSalesPricePlan[]       @relation("StoreSalesPricePlanUpdatedBy")
  createdHeadquartersExpenses       HeadquartersExpense[]       @relation("HeadquartersExpenseCreatedBy")
  updatedHeadquartersExpenses       HeadquartersExpense[]       @relation("HeadquartersExpenseUpdatedBy")
  auditLogs                         AuditLog[]                  @relation("AuditActor")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  actorId    String
  before     Json?
  after      Json?
  reason     String?
  createdAt  DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([createdAt])
  @@index([targetType, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
}

model AnomalyThresholdSetting {
  id                          String   @id @default(cuid())
  scope                       String   @unique @default("GLOBAL")
  marginRateBps               Int
  inventoryDifferenceQuantity Int
  isActive                    Boolean  @default(true)
  updatedById                 String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  updatedBy User? @relation("AnomalyThresholdSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([updatedById])
}

model DailyLedger {
  id                         String                      @id @default(cuid())
  storeId                    String
  closingDate                DateTime
  status                     DailyLedgerStatus           @default(IN_PROGRESS)
  version                    Int                         @default(1)
  authorDisplayName          String?
  totalSalesAmount           Int                         @default(0)
  cashAmount                 Int                         @default(0)
  cardAmount                 Int                         @default(0)
  otherPaymentAmount         Int                         @default(0)
  workerCount                Int?
  workMemo                   String?
  submittedById              String?
  submittedAt                DateTime?
  closedById                 String?
  closedAt                   DateTime?
  ledgerExpenses             LedgerExpense[]
  ledgerPurchaseItems        LedgerPurchaseItem[]
  ledgerInventoryItems       LedgerInventoryItem[]
  ledgerInventoryFifoLots    LedgerInventoryFifoLot[]
  ledgerInventoryAdjustments LedgerInventoryAdjustment[]
  ledgerLossItems            LedgerLossItem[]
  ledgerLaborItems           LedgerLaborItem[]
  correctionRecords          CorrectionRecord[]
  createdById                String
  updatedById                String
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  store       Store @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy   User  @relation("LedgerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User  @relation("LedgerUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  submittedBy User? @relation("LedgerSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  closedBy    User? @relation("LedgerClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([storeId, closingDate], map: "dailyLedger_storeId_closingDate_key")
  @@index([storeId, closingDate])
  @@index([status])
  @@index([submittedById])
  @@index([closedById])
}

model CorrectionRecord {
  id                   String               @id @default(cuid())
  dailyLedgerId        String
  targetType           CorrectionTargetType
  targetId             String
  fieldKey             String
  originalValue        Json
  previousAppliedValue Json
  correctedValue       Json
  reason               String
  createdById          String
  createdAt            DateTime             @default(now())

  dailyLedger DailyLedger @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  createdBy   User        @relation("CorrectionRecordCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([createdById])
  @@index([createdAt])
  @@index([dailyLedgerId, targetType, targetId, fieldKey, createdAt])
}

model LedgerExpense {
  id                String   @id @default(cuid())
  dailyLedgerId     String
  ledgerInputCodeId String
  amount            Int
  memo              String?
  createdById       String
  updatedById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dailyLedger     DailyLedger     @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  ledgerInputCode LedgerInputCode @relation(fields: [ledgerInputCodeId], references: [id], onDelete: Restrict)
  createdBy       User            @relation("LedgerExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User            @relation("LedgerExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([ledgerInputCodeId])
}

model LedgerPurchaseItem {
  id                 String               @id @default(cuid())
  dailyLedgerId      String
  productId          String?
  purchaseStandardId String?
  sourceType         LedgerPurchaseSource @default(MANUAL)
  productName        String
  productCategory    String
  productSpec        String
  unitPrice          Int
  quantity           Int
  amount             Int
  referenceInfo      String?
  createdById        String
  updatedById        String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  dailyLedger             DailyLedger              @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product                 Product?                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchaseStandard        PurchaseStandard?        @relation(fields: [purchaseStandardId], references: [id], onDelete: SetNull)
  ledgerInventoryFifoLots LedgerInventoryFifoLot[]
  createdBy               User                     @relation("LedgerPurchaseItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy               User                     @relation("LedgerPurchaseItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([productId])
  @@index([purchaseStandardId])
  @@index([sourceType])
}

model LedgerInventoryItem {
  id                String                   @id @default(cuid())
  dailyLedgerId     String
  productId         String
  productName       String
  productCategory   String
  productSpec       String
  unitPrice         Int
  previousQuantity  Int
  purchasedQuantity Int                      @default(0)
  currentQuantity   Int?
  quantity          Int?
  inventoryAmount   Int?
  isModified        Boolean                  @default(false)
  carryoverSource   InventoryCarryoverSource @default(MANUAL)
  carryoverStatus   InventoryCarryoverStatus @default(DATA_INSUFFICIENT)
  carryoverLedgerId String?
  createdById       String
  updatedById       String
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  dailyLedger               DailyLedger                     @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product                   Product                         @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy                 User                            @relation("LedgerInventoryItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy                 User                            @relation("LedgerInventoryItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  ledgerInventoryAdjustment LedgerInventoryAdjustment?
  carryoverDetail           LedgerInventoryCarryoverDetail?
  fifoLots                  LedgerInventoryFifoLot[]

  @@unique([dailyLedgerId, productId], map: "ledgerInventoryItem_dailyLedgerId_productId_key")
  @@index([dailyLedgerId])
  @@index([productId])
  @@index([carryoverLedgerId])
}

model LedgerInventoryCarryoverDetail {
  id                      String                   @id @default(cuid())
  ledgerInventoryItemId   String                   @unique
  source                  InventoryCarryoverSource
  status                  InventoryCarryoverStatus
  resolvedQuantity        Int
  sourceLedgerId          String?
  sourceLedgerClosingDate DateTime?
  sourceLedgerStatus      DailyLedgerStatus?
  sourceYearMonth         String?
  sourceSnapshotId        String?
  sourcePreviousQuantity  Int?
  sourcePurchasedQuantity Int?
  sourceLossQuantity      Int?
  sourceCurrentQuantity   Int?
  sourceQuantity          Int?
  message                 String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  ledgerInventoryItem LedgerInventoryItem @relation(fields: [ledgerInventoryItemId], references: [id], onDelete: Cascade)

  @@index([sourceLedgerId])
  @@index([sourceSnapshotId])
  @@index([source, status])
}

model LedgerInventoryFifoLot {
  id                    String             @id @default(cuid())
  dailyLedgerId         String
  ledgerInventoryItemId String?
  productId             String
  sourceType            InventoryLotSource
  sourceLedgerId        String?
  sourcePurchaseItemId  String?
  unitPrice             Int
  originalQuantity      Int
  consumedQuantity      Int
  remainingQuantity     Int
  originalAmount        Int
  consumedAmount        Int
  remainingAmount       Int
  sortOrder             Int
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  dailyLedger         DailyLedger          @relation(fields: [dailyLedgerId], references: [id], onDelete: Cascade)
  ledgerInventoryItem LedgerInventoryItem? @relation(fields: [ledgerInventoryItemId], references: [id], onDelete: Cascade)
  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  sourcePurchaseItem  LedgerPurchaseItem?  @relation(fields: [sourcePurchaseItemId], references: [id], onDelete: SetNull)

  @@unique([dailyLedgerId, productId, sortOrder], map: "ledgerInventoryFifoLot_dailyLedgerId_productId_sortOrder_key")
  @@index([dailyLedgerId, productId])
  @@index([ledgerInventoryItemId])
  @@index([productId])
  @@index([sourceType])
  @@index([sourcePurchaseItemId])
}

model LedgerInventoryAdjustment {
  id                    String                          @id @default(cuid())
  dailyLedgerId         String
  productId             String
  ledgerInventoryItemId String?                         @unique
  productName           String
  productCategory       String
  productSpec           String
  unitPrice             Int
  beforeQuantity        Int
  beforeAmount          Int
  afterQuantity         Int
  afterAmount           Int
  differenceQuantity    Int
  differenceAmount      Int
  amountStatus          InventoryAdjustmentAmountStatus @default(POLICY_UNCONFIRMED)
  reason                String
  createdById           String
  updatedById           String
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  dailyLedger         DailyLedger          @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  ledgerInventoryItem LedgerInventoryItem? @relation(fields: [ledgerInventoryItemId], references: [id], onDelete: SetNull)
  createdBy           User                 @relation("LedgerInventoryAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy           User                 @relation("LedgerInventoryAdjustmentUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@unique([dailyLedgerId, productId], map: "ledgerInventoryAdjustment_dailyLedgerId_productId_key")
  @@index([dailyLedgerId])
  @@index([productId])
  @@index([createdById])
  @@index([updatedById])
}

model LedgerLossItem {
  id                String   @id @default(cuid())
  dailyLedgerId     String
  productId         String
  ledgerInputCodeId String
  productName       String
  productCategory   String
  productSpec       String
  unitPrice         Int
  lossTypeName      String
  quantity          Int
  amount            Int
  reason            String
  createdById       String
  updatedById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dailyLedger     DailyLedger     @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  ledgerInputCode LedgerInputCode @relation(fields: [ledgerInputCodeId], references: [id], onDelete: Restrict)
  createdBy       User            @relation("LedgerLossItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User            @relation("LedgerLossItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([productId])
  @@index([ledgerInputCodeId])
  @@index([createdById])
  @@index([updatedById])
}

// WO-05(2026-06-22): 일일 장부에 종속된 라인 단위 인건비/급여 기록.
// DailyLedger.workerCount/workMemo는 단순 요약 역할을 유지하고, 직원별 이름·금액·
// 지각/조퇴/특이사항은 이 모델에 별도로 저장한다.
model LedgerLaborItem {
  id             String   @id @default(cuid())
  dailyLedgerId  String
  employeeId     String?
  workerName     String
  amount         Int
  lateMemo       String?
  earlyLeaveMemo String?
  specialMemo    String?
  createdById    String
  updatedById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dailyLedger DailyLedger  @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  employee    Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdBy   User         @relation("LedgerLaborItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User         @relation("LedgerLaborItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([employeeId])
  @@index([createdById])
  @@index([updatedById])
}

model InventoryOpeningSnapshot {
  id              String   @id @default(cuid())
  storeId         String
  yearMonth       String
  productId       String
  productName     String
  productCategory String
  productSpec     String
  unitPrice       Int
  quantity        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([storeId, yearMonth, productId], map: "inventoryOpeningSnapshot_storeId_yearMonth_productId_key")
  @@index([storeId, yearMonth])
  @@index([productId])
}

// WO-06(2026-06-22): 개점 전 지점장이 입력하는 품목별 예상 판매가 계획.
// DailyLedger와는 독립된 운영 계획 엔티티로, 지점/영업일/품목 단위로 1행을 유지한다.
// 실제 품목별 판매가가 없으므로 계획-실적 비교 금액은 모두 추정(estimated)으로만 노출한다.
model StoreSalesPricePlan {
  id               String   @id @default(cuid())
  storeId          String
  businessDate     DateTime
  productId        String
  plannedUnitPrice Int
  memo             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      String
  updatedById      String

  store     Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy User    @relation("StoreSalesPricePlanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User    @relation("StoreSalesPricePlanUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@unique([storeId, businessDate, productId], map: "storeSalesPricePlan_storeId_businessDate_productId_key")
  @@index([storeId, businessDate])
  @@index([productId])
  @@index([createdById])
  @@index([updatedById])
}

// WO-07(2026-06-22): 본사 전용 지출. 지점 일일 장부(DailyLedger)의 비용과 분리된
// 별도 엔티티로, 지점장에게는 노출하지 않고 본사 P&L/리포트에만 별도 라인으로 반영한다.
// storeId는 선택 사항이며, 지정 시 본사 사용자의 지점 권한 범위 내여야 한다(귀속 표시용).
model HeadquartersExpense {
  id          String   @id @default(cuid())
  expenseDate DateTime
  storeId     String?
  category    String
  amount      Int
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  updatedById String

  store     Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdBy User   @relation("HeadquartersExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User   @relation("HeadquartersExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([expenseDate])
  @@index([storeId, expenseDate])
  @@index([createdById])
  @@index([updatedById])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// WO-11(2026-06-22): 이카운트 매입 미리보기 세션. preview 시 서버에서 파싱한 rows를 저장하고,
// commit은 importSessionId만 받아 여기서 rows를 읽는다. 클라이언트 rows 조작을 원천 차단한다.
model EcountImportSession {
  id          String   @id @default(cuid())
  ledgerId    String
  actorId     String
  purchasesJson Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([ledgerId])
  @@index([actorId])
  @@index([expiresAt])
}

// WO-08(2026-06-22): 직원 마스터. 일일 장부의 LedgerLaborItem과 선택적으로 연결하여
// 본사에서 직원별 월간 급여 롤업을 집계할 수 있다. 기존 자유텍스트 workerName 행은 그대로 동작한다.
model Employee {
  id        String   @id @default(cuid())
  name      String
  hireDate  DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  laborItems LedgerLaborItem[]

  @@index([isActive])
}

// WO-10(2026-06-22): LINE 아침 요약 알림 전송 로그.
// 알림 provider, 템플릿 키, 수신자 ID, 전송 상태를 기록한다.
model NotificationDeliveryLog {
  id          String   @id @default(cuid())
  provider    String
  templateKey String
  recipientId String
  sentAt      DateTime @default(now())
  status      String
  error       String?

  @@index([templateKey, sentAt])
  @@index([recipientId, sentAt])
}
