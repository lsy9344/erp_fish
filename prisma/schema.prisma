// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

enum UserRole {
  HEADQUARTERS
  STORE_MANAGER
}

enum StoreAccessMode {
  ALL_STORES
  ASSIGNED_STORES
}

enum PermissionAction {
  LEDGER_CREATE
  LEDGER_EDIT
  LEDGER_HQ_CLOSE
  CORRECTION_CREATE
  UPLOAD_PREVIEW
  UPLOAD_COMMIT
  SETTINGS_MANAGE
  REPORT_VIEW
  EXPORT_CREATE
  USER_PERMISSION_MANAGE
}

enum DailyLedgerStatus {
  IN_PROGRESS
  IN_REVIEW
  HEADQUARTERS_CLOSED
  HOLIDAY
}

enum LedgerInputCodeGroup {
  PAYMENT_METHOD
  EXPENSE_ITEM
  LOSS_TYPE
}

enum InventoryCarryoverSource {
  OPENING_SNAPSHOT
  PREVIOUS_CLOSED_LEDGER
  MANUAL
}

enum CorrectionTargetType {
  LEDGER_FIELD
  PAYMENT_FIELD
  EXPENSE_ROW
  PURCHASE_ROW
  INVENTORY_ROW
  LOSS_ROW
  CALCULATED_METRIC
}

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

model Store {
  id          String   @id @default(cuid())
  name        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  assignments               UserStoreAssignment[]
  updatedBy                 User?                      @relation("StoreUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  dailyLedgers              DailyLedger[]
  inventoryOpeningSnapshots InventoryOpeningSnapshot[]

  @@index([isActive])
  @@index([updatedById])
}

model Product {
  id               String   @id @default(cuid())
  name             String
  category         String
  spec             String
  defaultUnitPrice Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  updatedById      String?

  updatedBy                  User?                       @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  purchaseStandards          PurchaseStandard[]
  ledgerPurchaseItems        LedgerPurchaseItem[]
  ledgerInventoryItems       LedgerInventoryItem[]
  ledgerInventoryAdjustments LedgerInventoryAdjustment[]
  ledgerLossItems            LedgerLossItem[]
  inventoryOpeningSnapshots  InventoryOpeningSnapshot[]

  @@unique([name, category, spec])
  @@index([category])
  @@index([isActive])
  @@index([updatedById])
}

model PurchaseStandard {
  id                String   @id @default(cuid())
  productId         String
  standardUnitPrice Int?
  referenceInfo     String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedById       String?

  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  updatedBy           User?                @relation("PurchaseStandardUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  ledgerPurchaseItems LedgerPurchaseItem[]

  @@index([productId])
  @@index([isActive])
  @@index([updatedById])
}

model LedgerInputCode {
  id           String               @id @default(cuid())
  group        LedgerInputCodeGroup
  name         String
  displayOrder Int
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  updatedById  String?

  updatedBy       User?            @relation("LedgerInputCodeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  ledgerExpenses  LedgerExpense[]
  ledgerLossItems LedgerLossItem[]

  @@unique([group, name])
  @@index([group, displayOrder])
  @@index([isActive])
  @@index([updatedById])
}

model UserStoreAssignment {
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@index([storeId])
}

model PermissionProfile {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  description     String?
  isSystem        Boolean         @default(false)
  isActive        Boolean         @default(true)
  storeAccessMode StoreAccessMode
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  actions PermissionProfileAction[]
  users   UserPermissionProfile[]

  @@index([isActive])
  @@index([storeAccessMode])
}

model PermissionProfileAction {
  profileId String
  action    PermissionAction
  createdAt DateTime         @default(now())

  profile PermissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([profileId, action])
  @@index([action])
}

model UserPermissionProfile {
  userId    String
  profileId String
  createdAt DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile PermissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([userId, profileId])
  @@index([profileId])
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                String                      @id @default(cuid())
  name                              String?
  email                             String?                     @unique
  emailVerified                     DateTime?
  image                             String?
  role                              UserRole                    @default(STORE_MANAGER)
  passwordHash                      String?
  isActive                          Boolean                     @default(true)
  createdAt                         DateTime                    @default(now())
  updatedAt                         DateTime                    @default(now()) @updatedAt
  accounts                          Account[]
  sessions                          Session[]
  posts                             Post[]
  storeAssignments                  UserStoreAssignment[]
  permissionProfiles                UserPermissionProfile[]
  updatedStores                     Store[]                     @relation("StoreUpdatedBy")
  updatedProducts                   Product[]                   @relation("ProductUpdatedBy")
  updatedPurchaseStandards          PurchaseStandard[]          @relation("PurchaseStandardUpdatedBy")
  updatedLedgerInputCodes           LedgerInputCode[]           @relation("LedgerInputCodeUpdatedBy")
  updatedAnomalyThresholdSettings   AnomalyThresholdSetting[]   @relation("AnomalyThresholdSettingUpdatedBy")
  createdDailyLedgers               DailyLedger[]               @relation("LedgerCreatedBy")
  updatedDailyLedgers               DailyLedger[]               @relation("LedgerUpdatedBy")
  submittedDailyLedgers             DailyLedger[]               @relation("LedgerSubmittedBy")
  closedDailyLedgers                DailyLedger[]               @relation("LedgerClosedBy")
  createdLedgerExpenses             LedgerExpense[]             @relation("LedgerExpenseCreatedBy")
  updatedLedgerExpenses             LedgerExpense[]             @relation("LedgerExpenseUpdatedBy")
  createdLedgerPurchaseItems        LedgerPurchaseItem[]        @relation("LedgerPurchaseItemCreatedBy")
  updatedLedgerPurchaseItems        LedgerPurchaseItem[]        @relation("LedgerPurchaseItemUpdatedBy")
  createdLedgerInventoryItems       LedgerInventoryItem[]       @relation("LedgerInventoryItemCreatedBy")
  updatedLedgerInventoryItems       LedgerInventoryItem[]       @relation("LedgerInventoryItemUpdatedBy")
  createdLedgerInventoryAdjustments LedgerInventoryAdjustment[] @relation("LedgerInventoryAdjustmentCreatedBy")
  updatedLedgerInventoryAdjustments LedgerInventoryAdjustment[] @relation("LedgerInventoryAdjustmentUpdatedBy")
  createdLedgerLossItems            LedgerLossItem[]            @relation("LedgerLossItemCreatedBy")
  updatedLedgerLossItems            LedgerLossItem[]            @relation("LedgerLossItemUpdatedBy")
  createdCorrectionRecords          CorrectionRecord[]          @relation("CorrectionRecordCreatedBy")
  auditLogs                         AuditLog[]                  @relation("AuditActor")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  actorId    String
  before     Json?
  after      Json?
  reason     String?
  createdAt  DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([createdAt])
  @@index([targetType, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
}

model AnomalyThresholdSetting {
  id                          String   @id @default(cuid())
  scope                       String   @unique @default("GLOBAL")
  salesDropRateBps            Int
  grossMarginDropBps          Int
  salesDifferenceAmount       Int
  lossAmount                  Int
  inventoryDifferenceQuantity Int
  updatedById                 String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  updatedBy User? @relation("AnomalyThresholdSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
}

model DailyLedger {
  id                         String                      @id @default(cuid())
  storeId                    String
  closingDate                DateTime
  status                     DailyLedgerStatus           @default(IN_PROGRESS)
  version                    Int                         @default(1)
  authorDisplayName          String?
  totalSalesAmount           Int                         @default(0)
  cashAmount                 Int                         @default(0)
  cardAmount                 Int                         @default(0)
  otherPaymentAmount         Int                         @default(0)
  workerCount                Int?
  workMemo                   String?
  submittedById              String?
  submittedAt                DateTime?
  closedById                 String?
  closedAt                   DateTime?
  ledgerExpenses             LedgerExpense[]
  ledgerPurchaseItems        LedgerPurchaseItem[]
  ledgerInventoryItems       LedgerInventoryItem[]
  ledgerInventoryAdjustments LedgerInventoryAdjustment[]
  ledgerLossItems            LedgerLossItem[]
  correctionRecords          CorrectionRecord[]
  createdById                String
  updatedById                String
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  store       Store @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy   User  @relation("LedgerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User  @relation("LedgerUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  submittedBy User? @relation("LedgerSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  closedBy    User? @relation("LedgerClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([storeId, closingDate], map: "dailyLedger_storeId_closingDate_key")
  @@index([storeId, closingDate])
  @@index([status])
  @@index([submittedById])
  @@index([closedById])
}

model CorrectionRecord {
  id                   String               @id @default(cuid())
  dailyLedgerId        String
  targetType           CorrectionTargetType
  targetId             String
  fieldKey             String
  originalValue        Json
  previousAppliedValue Json
  correctedValue       Json
  reason               String
  createdById          String
  createdAt            DateTime             @default(now())

  dailyLedger DailyLedger @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  createdBy   User        @relation("CorrectionRecordCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([createdById])
  @@index([createdAt])
  @@index([dailyLedgerId, targetType, targetId, fieldKey, createdAt])
}

model LedgerExpense {
  id                String   @id @default(cuid())
  dailyLedgerId     String
  ledgerInputCodeId String
  amount            Int
  memo              String?
  createdById       String
  updatedById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dailyLedger     DailyLedger     @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  ledgerInputCode LedgerInputCode @relation(fields: [ledgerInputCodeId], references: [id], onDelete: Restrict)
  createdBy       User            @relation("LedgerExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User            @relation("LedgerExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([ledgerInputCodeId])
}

model LedgerPurchaseItem {
  id                 String   @id @default(cuid())
  dailyLedgerId      String
  productId          String
  purchaseStandardId String?
  productName        String
  productCategory    String
  productSpec        String
  unitPrice          Int
  quantity           Int
  amount             Int
  referenceInfo      String?
  createdById        String
  updatedById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  dailyLedger      DailyLedger       @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchaseStandard PurchaseStandard? @relation(fields: [purchaseStandardId], references: [id], onDelete: SetNull)
  createdBy        User              @relation("LedgerPurchaseItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy        User              @relation("LedgerPurchaseItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([productId])
  @@index([purchaseStandardId])
}

model LedgerInventoryItem {
  id                String                   @id @default(cuid())
  dailyLedgerId     String
  productId         String
  productName       String
  productCategory   String
  productSpec       String
  unitPrice         Int
  previousQuantity  Int
  purchasedQuantity Int                      @default(0)
  currentQuantity   Int?
  quantity          Int?
  inventoryAmount   Int?
  isModified        Boolean                  @default(false)
  carryoverSource   InventoryCarryoverSource @default(MANUAL)
  carryoverLedgerId String?
  createdById       String
  updatedById       String
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  dailyLedger               DailyLedger                @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product                   Product                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy                 User                       @relation("LedgerInventoryItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy                 User                       @relation("LedgerInventoryItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  ledgerInventoryAdjustment LedgerInventoryAdjustment?

  @@unique([dailyLedgerId, productId], map: "ledgerInventoryItem_dailyLedgerId_productId_key")
  @@index([dailyLedgerId])
  @@index([productId])
  @@index([carryoverLedgerId])
}

model LedgerInventoryAdjustment {
  id                    String   @id @default(cuid())
  dailyLedgerId         String
  productId             String
  ledgerInventoryItemId String?  @unique
  productName           String
  productCategory       String
  productSpec           String
  unitPrice             Int
  beforeQuantity        Int
  beforeAmount          Int
  afterQuantity         Int
  afterAmount           Int
  differenceQuantity    Int
  differenceAmount      Int
  reason                String
  createdById           String
  updatedById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  dailyLedger         DailyLedger          @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  ledgerInventoryItem LedgerInventoryItem? @relation(fields: [ledgerInventoryItemId], references: [id], onDelete: SetNull)
  createdBy           User                 @relation("LedgerInventoryAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy           User                 @relation("LedgerInventoryAdjustmentUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@unique([dailyLedgerId, productId], map: "ledgerInventoryAdjustment_dailyLedgerId_productId_key")
  @@index([dailyLedgerId])
  @@index([productId])
  @@index([createdById])
  @@index([updatedById])
}

model LedgerLossItem {
  id                String   @id @default(cuid())
  dailyLedgerId     String
  productId         String
  ledgerInputCodeId String
  productName       String
  productCategory   String
  productSpec       String
  unitPrice         Int
  lossTypeName      String
  quantity          Int
  amount            Int
  reason            String
  createdById       String
  updatedById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dailyLedger     DailyLedger     @relation(fields: [dailyLedgerId], references: [id], onDelete: Restrict)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  ledgerInputCode LedgerInputCode @relation(fields: [ledgerInputCodeId], references: [id], onDelete: Restrict)
  createdBy       User            @relation("LedgerLossItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User            @relation("LedgerLossItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([dailyLedgerId])
  @@index([productId])
  @@index([ledgerInputCodeId])
  @@index([createdById])
  @@index([updatedById])
}

model InventoryOpeningSnapshot {
  id              String   @id @default(cuid())
  storeId         String
  yearMonth       String
  productId       String
  productName     String
  productCategory String
  productSpec     String
  unitPrice       Int
  quantity        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([storeId, yearMonth, productId], map: "inventoryOpeningSnapshot_storeId_yearMonth_productId_key")
  @@index([storeId, yearMonth])
  @@index([productId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
