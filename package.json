{
  "name": "erp-fish",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "pnpm lint && pnpm typecheck",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset:neon": "node --experimental-strip-types scripts/reset-neon-data.mjs",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check:ci-docs": "prettier --check .github/workflows/ci.yml docs/ci.md docs/ci-secrets-checklist.md docs/release-checklist.md _bmad-output/test-artifacts/ci-pipeline-progress.md README.md",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "next build && next start",
    "release:preflight": "pnpm db:validate && pnpm format:check && pnpm format:check:ci-docs && pnpm typecheck && pnpm lint && pnpm build && pnpm test:unit && pnpm test:api && pnpm test:e2e:core && git diff --check",
    "start": "next start",
    "test:api": "node scripts/run-playwright-clean.mjs tests/api",
    "test:e2e": "node scripts/run-playwright-clean.mjs tests/e2e",
    "test:e2e:core": "pnpm test:e2e:core:ledger && pnpm test:e2e:core:hq && pnpm test:e2e:core:admin && pnpm test:e2e:core:imports",
    "test:e2e:core:admin": "node scripts/run-playwright-clean.mjs tests/e2e/permission-profiles.spec.ts tests/e2e/master-data-stores.spec.ts tests/e2e/master-data-purchase-standards.spec.ts tests/e2e/anomaly-thresholds.spec.ts",
    "test:e2e:core:hq": "node scripts/run-playwright-clean.mjs tests/e2e/hq-dashboard.spec.ts tests/e2e/hq-ledger-edit.spec.ts tests/e2e/hq-ledger-corrections.spec.ts tests/e2e/hq-reports.spec.ts",
    "test:e2e:core:imports": "node scripts/run-playwright-clean.mjs tests/e2e/ecount-supply-imports.spec.ts",
    "test:e2e:core:ledger": "node scripts/run-playwright-clean.mjs tests/e2e/store-ledger-sales.spec.ts tests/e2e/store-ledger-purchase.spec.ts tests/e2e/store-ledger-inventory.spec.ts tests/e2e/store-ledger-inventory-adjustment.spec.ts tests/e2e/store-ledger-losses.spec.ts tests/e2e/store-ledger-review.spec.ts",
    "test:e2e:meeting-0627": "node scripts/run-playwright-clean.mjs tests/e2e/meeting-0627-acceptance.spec.ts",
    "test:e2e:smoke:admin": "node scripts/run-playwright-clean.mjs tests/e2e/permission-profiles.spec.ts --grep \"지점장 입력 화면을 직접 열 수 없다\"",
    "test:e2e:smoke:hq": "node scripts/run-playwright-clean.mjs tests/e2e/hq-dashboard.spec.ts --grep \"활성 지점 전체와 장부 상태\"",
    "test:e2e:smoke:ledger": "node scripts/run-playwright-clean.mjs tests/e2e/store-ledger-inventory.spec.ts --grep \"FIFO 재고금액\"",
    "test:playwright": "node scripts/run-playwright-clean.mjs",
    "test:unit": "node --experimental-strip-types --test tests/unit/*.test.mjs",
    "test:unit:file": "node --experimental-strip-types --test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.7.2",
    "@prisma/client": "^6.6.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.17.0",
    "next": "^15.2.3",
    "next-auth": "5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.60.0",
    "@seontechnologies/playwright-utils": "4.3.0",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.6.0",
    "shadcn": "^4.8.2",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.31.0"
}
